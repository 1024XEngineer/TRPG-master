# `fake` runs the deterministic local demo; `pydantic-ai` calls the configured model.
AIDM_AGENT_MODE=fake

# PydanticAI model string. Install another provider extra if this is not OpenAI.
PYDANTIC_AI_MODEL=openai:gpt-5-mini

# Required only when AIDM_AGENT_MODE=pydantic-ai with an OpenAI model.
OPENAI_API_KEY=
