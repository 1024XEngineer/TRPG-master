{
  "_note": "ModuleContent v1 P2 Draft — 《幸福蛙蛙村》。此为 Contract Validation 阶段的示例映射，非可执行 JSON Schema。字段名使用当前 Contract 名称（scenes 而非 content_units）。",

  "module_id": "happy-frog-village",
  "version": "1.0.0",
  "world_ref": "coc-7e",

  "scenes": [
    {
      "id": "scene_manor",
      "name": "莱恩庄园",
      "content": "你们接到了一个找人的委托，来到了莱恩庄园，一位衣着华贵但面容憔悴的中年男人在管家的陪同下接待了你们。他是本市有名的企业家，理查德·莱恩先生。",
      "entity_ids": ["richard_lane", "butler", "flyer", "james_photo"],
      "checkpoint_ids": ["examine_flyer"],
      "exits": []
    },
    {
      "id": "scene_police_station",
      "name": "警局接待处",
      "content": "你们在警局处理文书工作时，被一阵焦急的争论声打断。一对衣着光鲜的夫妇——著名的企业家理查德·莱恩和他的夫人，正情绪激动地向你们的警长求助。",
      "entity_ids": ["richard_lane", "lane_wife", "sheriff", "flyer", "james_photo"],
      "checkpoint_ids": ["examine_flyer"],
      "exits": []
    },
    {
      "id": "scene_forest_edge",
      "name": "老林地边缘",
      "content": "在通往老林地的碎石路旁，一个身影蜷缩在一棵巨大的橡树下，浑身沾满泥泞。他看起来衣衫褴褛，正用双手死死捂住自己的耳朵，身体不住地颤抖。",
      "entity_ids": ["ezra"],
      "checkpoint_ids": ["spot_ezra", "calm_ezra"],
      "exits": ["scene_resort_entrance"]
    },
    {
      "id": "scene_resort_entrance",
      "name": "蛙蛙度假村入口/接待处",
      "content": "木制的牌匾上写着"蛙蛙度假村"，旁边画着一只可爱的卡通青蛙。空气清新湿润，隐约能听到悦耳的蛙鸣。一位身着修身女仆装、头戴蛙蛙发卡的年轻女性迎了上来。",
      "entity_ids": ["emily", "messenger", "tom", "james", "samantha", "resort_map"],
      "checkpoint_ids": ["psychology_emily", "psychology_messenger", "spot_staff_uniformity"],
      "exits": ["scene_guest_room", "scene_dining_kitchen", "scene_pond", "scene_staff_area"]
    },
    {
      "id": "scene_guest_room",
      "name": "客房",
      "content": "整洁舒适，床头柜上放着一本小册子，标题是《来一起拥抱幸福吧！》，里面充满了关于'放下自我，融入自然'、'幸福即在无忧的梦中'等箴言。",
      "entity_ids": ["happiness_booklet", "guest_npc"],
      "checkpoint_ids": ["read_booklet", "persuade_guests", "spot_guest_frog_features"],
      "exits": []
    },
    {
      "id": "scene_dining_kitchen",
      "name": "用餐区和厨房",
      "content": "常规食物（沙拉、汉堡、牛排等）本身没有问题。然而萨曼莎在烹饪之前总得洗菜。所有液体——饮用水、果汁、咖啡、汤品——其主要成分都是来自'蛙鸣泉'的池水。",
      "entity_ids": ["samantha", "water_barrel"],
      "checkpoint_ids": ["spot_water_source", "resist_drink"],
      "exits": []
    },
    {
      "id": "scene_pond",
      "name": "池塘区（蛙鸣泉）",
      "content": "这里是度假村的中心，青蛙的数量多得不正常。它们蹲在荷叶上、岸边，几乎一动不动。",
      "entity_ids": ["dream_frog", "frog_pond", "dream_crystal"],
      "checkpoint_ids": ["spot_frogs", "natural_history_frogs", "listen_frogs", "resist_pond_contact", "resist_pond_immersion", "dive_for_crystal", "dodge_frog_swarm"],
      "exits": []
    },
    {
      "id": "scene_staff_area",
      "name": "员工区",
      "content": "员工工作区，需要潜行或引开员工才能进入。",
      "entity_ids": ["storage_key", "staff_uniforms", "unfinished_flyers", "handwritten_notes"],
      "checkpoint_ids": ["stealth_staff_area", "find_storage_key", "find_notes"],
      "exits": ["scene_storage_room"]
    },
    {
      "id": "scene_storage_room",
      "name": "二楼杂物间",
      "content": "杂物间里堆满了散发着甜腻气味的'营养液'桶。如果调查员选择尝一口，便会直接倒地睡觉。",
      "entity_ids": ["nutrient_barrel"],
      "checkpoint_ids": [],
      "exits": []
    },
    {
      "id": "scene_boss_bedroom",
      "name": "老板卧室",
      "content": "你会在里面发现一个笔记。",
      "entity_ids": ["messenger_notes"],
      "checkpoint_ids": ["read_messenger_notes"],
      "exits": []
    },
    {
      "id": "scene_night_pond",
      "name": "夜间池塘",
      "content": "她深夜独自来到池塘边，跪在水边，双手浸入水中，身体发出微弱的磷光。池塘里的青蛙则如同朝圣般面向她，微微颤动。",
      "entity_ids": ["messenger", "dream_crystal", "dream_frog"],
      "checkpoint_ids": ["track_messenger_night", "night_con_check"],
      "exits": []
    }
  ],

