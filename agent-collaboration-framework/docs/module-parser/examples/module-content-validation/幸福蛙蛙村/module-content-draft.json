  "module_rules": [
    {
      "id": "drink_trigger",
      "hook": "on_interact",
      "priority": 100,
      "mode": "append",
      "when": { "expr": "action.target.kind == 'liquid'" },
      "then": [
        { "op": "force", "action": "resist_drink" }
      ],
      "facts": ["drink_consumed"],
      "player_visible_information": []
    },
    {
      "id": "pond_contact_trigger",
      "hook": "on_scene_enter",
      "priority": 100,
      "mode": "append",
      "when": { "path": "scenes.scene_pond.active", "equals": true },
      "then": [
        { "op": "force", "action": "resist_pond_contact" }
      ],
      "facts": ["pond_contact_occurred"],
      "player_visible_information": []
    },
    {
      "id": "cumulative_dependency",
      "hook": "on_state_change",
      "priority": 50,
      "mode": "append",
      "when": { "expr": "self.drink_failures >= 2" },
      "then": [
        { "op": "apply_condition", "condition": "psychological_dependency" }
      ],
      "facts": ["dependency_established"],
      "player_visible_information": ["你开始对这里的水产生了一种难以言喻的渴望……"]
    },
    {
      "id": "mutation_stage_2",
      "hook": "on_state_change",
      "priority": 80,
      "mode": "append",
      "when": { "expr": "self.mutation_stage == 1 && self.time_in_resort >= 24" },
      "then": [
        { "op": "add", "path": "self.mutation_stage", "value": 1 },
        { "op": "add", "path": "self.attr.jump", "value": "4d6" },
        { "op": "add", "path": "self.attr.appearance", "value": "-2d6" }
      ],
      "facts": ["mutation_stage_2_reached"],
      "player_visible_information": ["你感觉自己的皮肤变得格外湿滑清凉，喉咙也有些发痒，仿佛渴望发出某种声音……"]
    },
    {
      "id": "mutation_stage_3",
      "hook": "on_state_change",
      "priority": 80,
      "mode": "append",
      "when": { "expr": "self.mutation_stage >= 2 && self.time_in_resort >= 48" },
      "then": [
        { "op": "set", "path": "self.mutation_stage", "value": 3 },
        { "op": "set", "path": "self.attr.appearance", "value": 25 },
        { "op": "set", "path": "self.attr.jump", "value": 85 }
      ],
      "facts": ["mutation_stage_3_reached"],
      "player_visible_information": ["你长出了一颗青蛙脑袋……你开始出现大量幻觉……"]
    },
    {
      "id": "mutation_stage_4",
      "hook": "on_state_change",
      "priority": 80,
      "mode": "append",
      "when": { "expr": "self.mutation_stage >= 3 && self.time_in_resort >= 72" },
      "then": [
        { "op": "apply_condition", "condition": "full_transformation" },
        { "op": "trigger_ending", "ending_id": "ending_transformed" }
      ],
      "facts": ["full_transformation_complete"],
      "player_visible_information": ["你的身体缩小，变成了一只青蛙，跳入了池塘……"]
    },
    {
      "id": "frog_harmed_retaliation",
      "hook": "on_interact",
      "priority": 200,
      "mode": "override",
      "when": { "expr": "action.target.kind == 'frog' && action.type == 'harm'" },
      "then": [
        { "op": "force", "action": "summon_mutant_frog" }
      ],
      "facts": ["frog_harmed"],
      "player_visible_information": ["池塘里的几百只青蛙开始融合成一个巨型怪物……"]
    },
    {
      "id": "night_con_mutation",
      "hook": "on_time_elapsed",
      "priority": 70,
      "mode": "append",
      "when": { "expr": "clock.time_of_day == 'night'" },
      "then": [
        { "op": "force", "action": "night_con_check" }
      ],
      "facts": ["night_check_triggered"],
      "player_visible_information": []
    },
    {
      "id": "james_withdrawal",
      "hook": "on_state_change",
      "priority": 90,
      "mode": "append",
      "when": { "expr": "entity.james.location != 'resort'" },
      "then": [
        { "op": "apply_condition", "condition": "withdrawal_symptoms" }
      ],
      "facts": ["james_withdrawal_started"],
      "player_visible_information": ["詹姆斯开始呕吐、痉挛，身体异常虚弱……"]
    },
    {
      "id": "james_suicide",
      "hook": "on_state_change",
      "priority": 90,
      "mode": "append",
      "when": { "expr": "entity.james.location != 'resort' && entity.james.free_will == true" },
      "then": [
        { "op": "force", "action": "james_bite_tongue" }
      ],
      "facts": ["james_dead"],
      "player_visible_information": ["詹姆斯趁着大家都没注意直接咬舌自尽了……"]
    },
    {
      "id": "richard_accelerated_mutation",
      "hook": "on_state_change",
      "priority": 60,
      "mode": "append",
      "when": { "path": "entity.richard_lane.at_resort", "equals": true },
      "then": [
        { "op": "add", "path": "entity.richard_lane.mutation_rate", "value": 2 }
      ],
      "facts": ["richard_mutating_fast"],
      "player_visible_information": ["理查德喝了一口詹姆斯递来的水后，手指间竟然已经出现了淡淡的绿色蹼膜……"]
    }
  ],

  "checkpoints": [
    {
      "id": "calm_ezra",
      "scene_id": "scene_forest_edge",
      "action": "treat",
      "target_id": "ezra",
      "skills": ["psychoanalysis"],
      "difficulty": "regular",
      "outcomes": {
        "success": {
          "facts": ["ezra_identified", "messenger_not_human", "dreams_devour"],
