      "scene_id": "ghoul_confrontation",
      "action": "flee",
      "target_id": "ghoul_crowd",
      "skills": [],
      "difficulty": null,
      "outcomes": {
        "success": {
          "facts": ["调查员逃离墓地，食尸鬼群带走道格拉斯尸体"],
          "player_visible_information": [
            {
              "text": "你逃离了墓地。身后的食尸鬼没有追来，只把道格拉斯的尸体带回地下。",
              "visibility": {"audience": "all"}
            }
          ],
          "narration_constraints": ["原文明确食尸鬼不会追赶选择逃走的调查员。"],
          "ops": [
            {
              "op": "set",
              "path": "entity.case_tracker.state.douglas_body_removed",
              "value": true
            },
            {
              "op": "set",
              "path": "entity.case_tracker.state.investigation_resolved",
              "value": true
            }
          ]
        },
        "failure": {
          "facts": [],
          "player_visible_information": [],
          "narration_constraints": [],
          "ops": []
        }
      },
      "visibility": {
        "audience": "all",
        "requires_discovery": true,
        "discovery_rule": "entity.ghoul_crowd.state.revealed == true",
        "discovery_shares_to_party": true
      }
    }
  ],
  "win_conditions": [
    {
      "id": "ending_douglas_departs",
      "when": {
        "expr": "entity.douglas.state.truth_told == true && entity.douglas.state.left_forever == true && entity.case_tracker.state.investigator_disappeared == false"
      },
      "fact": "调查员与道格拉斯交谈并确认他不会再返回",
      "player_visible_information": "道格拉斯带着最后的藏书回到地下，食尸鬼封闭入口。托马斯此后再也没有受到打扰。",
      "is_ending": true
    },
    {
      "id": "ending_followed_underground",
      "when": {
        "path": "entity.case_tracker.state.investigator_disappeared",
        "equals": true
      },
      "fact": "调查员自愿或被迫进入食尸鬼地下世界并失踪",
      "player_visible_information": "地穴石板重新合拢，阿诺兹堡从此再没有人见过这名调查员。",
      "is_ending": true
    },
    {
      "id": "ending_asylum",
      "when": {
        "path": "entity.case_tracker.state.sent_to_asylum",
        "equals": true
      },
      "fact": "调查员在食尸鬼群前陷入临时疯狂并昏迷",
      "player_visible_information": "你在阿诺兹堡疗养院醒来。墓地没有留下食尸鬼的痕迹，托马斯此后也没有再被打扰。",
      "is_ending": true
    },
    {
      "id": "ending_douglas_killed_and_recovered",
      "when": {
        "expr": "entity.douglas.state.alive == false && entity.case_tracker.state.douglas_body_removed == true && entity.case_tracker.state.investigation_resolved == true"
      },
      "fact": "道格拉斯被杀，调查员逃离，食尸鬼群收走尸体",
      "player_visible_information": "食尸鬼把道格拉斯的尸体带回墓地深处。托马斯的生活恢复平静，但真相只留下恐怖的记忆。",
      "is_ending": true
    }
  ],
  "module_rules": [
    {
      "id": "enable_night_surveillance",
      "hook": "on_time_elapsed",
      "priority": 30,
      "mode": "append",
      "when": {
        "expr": "clock.time_of_day == 'night' && entity.case_tracker.state.surveillance_available == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.case_tracker.state.surveillance_available",
          "value": true
        }
      ],
      "facts": ["夜间可以监视金博尔宅或墓地"],
      "player_visible_information": []
    },
    {
      "id": "locked_study_window_breaks",
      "hook": "on_state_change",
      "priority": 80,
      "mode": "append",
      "when": {
        "expr": "entity.douglas.state.visit_observed == true && entity.study_window.state.locked == true && entity.study_window.state.broken == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.study_window.state.broken",
          "value": true
        }
      ],
      "facts": ["道格拉斯撞坏上锁的书房窗户"],
      "player_visible_information": [
        {
          "text": "人影用肩膀顶坏木条，玻璃碎裂后闯进了书房。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "first_sight_of_douglas",
      "hook": "on_state_change",
      "priority": 120,
      "mode": "append",
      "when": {
        "expr": "entity.douglas.state.true_form_seen == true && entity.case_tracker.state.first_ghoul_sight_resolved == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.case_tracker.state.first_ghoul_sight_resolved",
          "value": true
        },
        {
          "op": "force",
          "action": "coc7.san_check(0,1d6)"
        }
      ],
      "facts": ["调查员直视食尸鬼形态的道格拉斯"],
      "player_visible_information": [
        {
          "text": "人影转过身来；那张脸仍像道格拉斯，却已经不再属于人类。",
          "visibility": {"audience": "actor"}
        }
      ]
    },
    {
      "id": "douglas_never_initiates_attack",
      "hook": "on_attack_declare",
      "priority": 100,
      "mode": "forbid",
      "when": {
        "expr": "action.actor_id == 'douglas' && action.initiated_by_target == false"
      },
      "then": [],
      "facts": ["道格拉斯不会主动攻击调查员"],
      "player_visible_information": []
    },
    {
      "id": "douglas_death_reveals_identity",
      "hook": "on_death",
      "priority": 200,
      "mode": "append",
      "when": {
        "expr": "target.id == 'douglas' && entity.douglas.state.corpse_identified == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.douglas.state.alive",
          "value": false
        },
        {
          "op": "set",
          "path": "entity.douglas.state.corpse_identified",
          "value": true
        },
        {
          "op": "set",
          "path": "entity.douglas.state.true_form_seen",
          "value": true
        },
        {
          "op": "set",
          "path": "entity.case_tracker.state.douglas_identity_shock_resolved",
          "value": true
        },
        {
          "op": "set",
          "path": "entity.ghoul_crowd.state.revealed",
          "value": true
        },
        {
          "op": "transition",
          "scene_id": "ghoul_confrontation"
        },
        {
          "op": "force",
          "action": "coc7.san_check(1,1d8)"
        }
      ],
      "facts": ["死去的食尸鬼与道格拉斯惊人相似", "食尸鬼群开始现身"],
      "player_visible_information": [
        {
          "text": "倒下的食尸鬼与道格拉斯有着惊人的相似之处；四周同时响起了越来越密集的脚步声。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "ghoul_crowd_sanity",
      "hook": "on_state_change",
      "priority": 180,
      "mode": "append",
      "when": {
        "expr": "entity.ghoul_crowd.state.revealed == true && entity.case_tracker.state.crowd_sight_resolved == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.case_tracker.state.crowd_sight_resolved",
          "value": true
        },
        {
          "op": "force",
          "action": "coc7.san_check(0,1d6,habit_cap=6)"
        }
      ],
      "facts": ["调查员目击几十只食尸鬼"],
      "player_visible_information": [
        {
          "text": "几十只食尸鬼从夜幕中现身，把墓碑之间的退路围成一片蠕动的阴影。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "temporary_insanity_leads_to_asylum",
      "hook": "on_state_change",
      "priority": 170,
      "mode": "append",
      "when": {
        "expr": "entity.ghoul_crowd.state.revealed == true && actor.temporary_insanity == true && entity.case_tracker.state.sent_to_asylum == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.case_tracker.state.sent_to_asylum",
          "value": true
        },
        {
          "op": "apply_condition",
          "condition": "unconscious"
        }
      ],
      "facts": ["调查员尖叫后昏迷，并被送往阿诺兹堡疗养院"],
      "player_visible_information": [
        {
          "text": "尖叫耗尽了最后的意识。再次醒来时，你已经躺在阿诺兹堡疗养院。",
          "visibility": {"audience": "actor"}
        }
      ]
    },
    {
      "id": "attacking_ghoul_crowd_causes_disappearance",
      "hook": "on_attack_declare",
      "priority": 300,
      "mode": "override",
      "when": {
        "expr": "action.target_id == 'ghoul_crowd'"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.ghoul_crowd.state.hostile",
          "value": true
        },
        {
          "op": "set",
          "path": "entity.case_tracker.state.investigator_disappeared",
          "value": true
        },
        {
          "op": "force",
          "action": "ghouls_overwhelm_and_abduct_actor"
        }
      ],
      "facts": ["调查员试图攻击食尸鬼群并被制服带走"],
      "player_visible_information": [
        {
          "text": "枪声或攻击只让食尸鬼群一拥而上。你很快被压倒，并被拖向地下。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "crypt_stench_causes_fainting",
      "hook": "on_interact",
      "priority": 150,
      "mode": "override",
      "when": {
        "expr": "action.target_id == 'crypt_entrance' && action.type == 'enter' && action.declares('hold_breath') == false"
      },
      "then": [
        {
          "op": "apply_condition",
          "condition": "unconscious_until_night"
        },
        {
          "op": "set",
          "path": "entity.douglas.state.sighted",
          "value": true
        },
        {
          "op": "set",
          "path": "entity.douglas.state.willing_to_talk",
          "value": true
        },
        {
          "op": "transition",
          "scene_id": "conversation"
        }
      ],
      "facts": ["未屏住呼吸的调查员被地穴腐臭熏昏，夜间在墓碑旁醒来"],
      "player_visible_information": [
        {
          "text": "腐臭灌入肺中，你当场失去意识；夜里醒来时，道格拉斯正坐在旁边的墓碑上看着你。",
          "visibility": {"audience": "actor"}
        }
      ]
    }
  ],
  "information_items": [
    {
      "id": "lyla_cemetery_sighting",
      "content": "莱拉·奥戴尔曾看见道格拉斯夹着一本书往公墓方向走；但他本来走到哪里都带着书。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "melodias_night_sighting",
      "content": "梅洛迪亚斯深夜在公墓看见一个人影仍坐在道格拉斯常用的墓碑上，因为害怕而没有靠近。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "cemetery_dance_report",
      "content": "十多年前有人目击一群看似未着寸缕的人在公墓跳舞；警方没找到人，只留下形状怪异的脚印。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "hilda_ghoul_statement",
      "content": "希尔达·沃德称自己二十多年间常看到犬类面孔、蹄状足部、浑身腐泥的“恶魔子嗣”在墓地附近出没。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "diary_tunnel_clue",
      "content": "道格拉斯失踪前决定加入“我在地下的朋友们”；日记暗示公墓地下有神秘生物居住的隧道网络。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "douglas_true_nature",
      "content": "道格拉斯已经转化为食尸鬼，但仍保留记忆、人格和交谈能力。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "douglas_confession",
      "content": "道格拉斯厌倦人类社会，只想自由阅读；地下生活令他满足，食尸鬼即将关闭这处入口，他不会再回来，并请求调查员向托马斯隐瞒真相。",
      "visibility": {"audience": "keeper"}
    }
  ]
}
