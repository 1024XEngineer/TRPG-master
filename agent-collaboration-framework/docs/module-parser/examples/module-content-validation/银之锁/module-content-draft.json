              "text": "你回头看见绑架者手持匕首，正从银色房门方向一步步走近。",
              "visibility": {"audience": "actor"}
            }
          ],
          "narration_constraints": ["绑架者属性高于 PC，但原文没有给出固定数值，不得编造 StatBlock。"],
          "ops": [
            {
              "op": "set",
              "path": "entity.kidnapper.state.approached",
              "value": true
            }
          ]
        },
        "failure": {
          "facts": ["调查员没有及时发现身后的绑架者"],
          "player_visible_information": [
            {
              "text": "倒地的冲击让你没能立刻注意身后。",
              "visibility": {"audience": "actor"}
            }
          ],
          "narration_constraints": [],
          "ops": [
            {
              "op": "set",
              "path": "entity.kidnapper.state.approached",
              "value": true
            }
          ]
        }
      },
      "visibility": {
        "audience": "actor",
        "requires_discovery": true,
        "discovery_rule": "entity.silver_lock.state.boundary_triggered == true",
        "discovery_shares_to_party": false
      }
    },
    {
      "id": "escape_through_bright_door",
      "scene_id": "corridor",
      "action": "escape",
      "target_id": "bright_exit",
      "skills": [],
      "difficulty": null,
      "outcomes": {
        "success": {
          "facts": ["调查员在银之锁解除后逃出长廊"],
          "player_visible_information": [
            {
              "text": "脚踝上的无形束缚已经消失。你冲向亮门，终于离开了这片银色牢笼。",
              "visibility": {"audience": "all"}
            }
          ],
          "narration_constraints": [],
          "ops": [
            {
              "op": "set",
              "path": "entity.bright_exit.state.reached",
              "value": true
            },
            {
              "op": "set",
              "path": "entity.escape_tracker.state.escaped",
              "value": true
            },
            {
              "op": "transition",
              "scene_id": "outside"
            }
          ]
        },
        "failure": {
          "facts": ["银之锁仍在阻止调查员接近出口"],
          "player_visible_information": [
            {
              "text": "左脚踝再次被无形力量锁住，你无法接近亮门。",
              "visibility": {"audience": "actor"}
