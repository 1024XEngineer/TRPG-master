        "discovery_rule": "entity.silver_lock.state.active == false",
        "discovery_shares_to_party": true
      }
    }
  ],
  "win_conditions": [
    {
      "id": "ending_escape",
      "when": {
        "path": "entity.escape_tracker.state.escaped",
        "equals": true
      },
      "fact": "调查员在芭斯特牺牲、银之锁解除后逃出长廊",
      "player_visible_information": "银之锁的束缚已经消失。你穿过长廊尽头的亮门，终于重获自由。",
      "is_ending": true
    },
    {
      "id": "ending_kidnapper_killed",
      "when": {
        "expr": "entity.silver_lock.state.active == false && entity.kidnapper.state.alive == false"
      },
      "fact": "调查员在银之锁解除后杀死绑架者",
      "player_visible_information": "芭斯特的牺牲让银之锁碎裂。你夺取匕首结束了绑架者的威胁，通往外界的路已经打开。",
      "is_ending": true
    }
  ],
  "module_rules": [
    {
      "id": "pulling_rat_thing_causes_injury",
      "hook": "on_interact",
      "priority": 120,
      "mode": "override",
      "when": {
        "expr": "action.target_id == 'rat_thing' && action.type == 'pull_down'"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.rat_thing.state.pulled_down",
          "value": true
        },
        {
          "op": "force",
          "action": "coc7.hp_loss(1d3)"
        },
        {
          "op": "force",
          "action": "rat_thing_attack(1d4-2)"
        }
      ],
      "facts": ["调查员强行扯下人面鼠并额外受伤"],
      "player_visible_information": [
        {
          "text": "你强行把人面鼠从管道里扯下，尖锐边缘和怪物的挣扎立刻撕伤了你。",
          "visibility": {"audience": "actor"}
        }
      ]
    },
    {
      "id": "silver_lock_trips_at_boundary",
      "hook": "on_scene_enter",
      "priority": 200,
      "mode": "append",
      "when": {
        "expr": "scene.id == 'corridor' && entity.silver_lock.state.active == true && entity.silver_lock.state.boundary_triggered == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.silver_lock.state.boundary_triggered",
          "value": true
        },
        {
          "op": "force",
          "action": "trip_actor_at_silver_lock_boundary"
        },
        {
          "op": "force",
          "action": "keeper_remove_overpowered_equipment_if_applicable"
        }
      ],
      "facts": ["调查员左脚踝在银之锁边缘被束缚并向前摔倒"],
      "player_visible_information": [
        {
          "text": "刚走出一小段，左脚踝突然像被锁住一样停在原地，你整个人向前摔倒。",
          "visibility": {"audience": "actor"}
        }
      ]
    },
    {
      "id": "cat_attacks_kidnapper",
      "hook": "on_state_change",
      "priority": 180,
      "mode": "append",
      "when": {
        "expr": "entity.silver_lock.state.boundary_triggered == true && entity.cat_bast.state.alive == true && entity.cat_bast.state.rescued == true && entity.kidnapper.state.blinded == false"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.kidnapper.state.blinded",
          "value": true
        },
        {
          "op": "trigger_rule",
          "rule_id": "kidnapper_kills_bast"
        }
      ],
      "facts": ["芭斯特跳到绑架者脸上抓瞎其双眼"],
      "player_visible_information": [
        {
          "text": "芭斯特突然跃上绑架者的脸，利爪划过双眼，惨叫声在长廊中炸开。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "kidnapper_kills_bast",
      "hook": "on_state_change",
      "priority": 170,
      "mode": "append",
      "when": {
        "expr": "entity.kidnapper.state.blinded == true && entity.cat_bast.state.alive == true"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.cat_bast.state.sacrificed_in_corridor",
          "value": true
        },
        {
          "op": "set",
          "path": "entity.cat_bast.state.alive",
          "value": false
        },
        {
          "op": "set",
          "path": "entity.kidnapper_dagger.state.available_to_player",
          "value": true
        },
        {
          "op": "trigger_rule",
          "rule_id": "silver_lock_dissolves"
        }
      ],
      "facts": ["绑架者用匕首杀死芭斯特"],
      "player_visible_information": [
        {
          "text": "失明的绑架者疯狂挥动匕首。芭斯特的叫声戛然而止，鲜血落在银色地面上。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "silver_lock_dissolves",
      "hook": "on_state_change",
      "priority": 160,
      "mode": "append",
      "when": {
        "expr": "entity.cat_bast.state.alive == false && entity.silver_lock.state.active == true"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.silver_lock.state.active",
          "value": false
        }
      ],
      "facts": ["作为法术核心的芭斯特死亡，银之锁解除"],
      "player_visible_information": [
        {
          "text": "芭斯特停止呼吸的瞬间，锁住脚踝的无形力量彻底消失了。",
          "visibility": {"audience": "all"}
        }
      ]
    },
    {
      "id": "kidnapper_recaptures_unprotected_actor",
      "hook": "on_state_change",
      "priority": 150,
      "mode": "append",
      "when": {
        "expr": "entity.silver_lock.state.boundary_triggered == true && entity.silver_lock.state.active == true && (entity.cat_bast.state.rescued == false || (entity.cat_bast.state.alive == false && entity.cat_bast.state.sacrificed_in_corridor == false))"
      },
      "then": [
        {
          "op": "add",
          "path": "entity.escape_tracker.state.recaptured_count",
          "value": 1
        },
        {
          "op": "set",
          "path": "entity.silver_lock.state.boundary_triggered",
          "value": false
        },
        {
          "op": "set",
          "path": "entity.silver_door.state.opened",
          "value": false
        },
        {
          "op": "transition",
          "scene_id": "sealed_room"
        },
        {
          "op": "force",
          "action": "reset_room_attempt"
        }
      ],
      "facts": ["没有芭斯特保护时，绑架者把调查员重新抓回房间"],
      "player_visible_information": [
        {
          "text": "绑架者轻易制服了倒地的你。再次恢复意识时，你又回到了那间银色房间。",
          "visibility": {"audience": "actor"}
        }
      ]
    },
    {
      "id": "record_kidnapper_death",
      "hook": "on_death",
      "priority": 100,
      "mode": "append",
      "when": {
        "expr": "target.id == 'kidnapper'"
      },
      "then": [
        {
          "op": "set",
          "path": "entity.kidnapper.state.alive",
          "value": false
        }
      ],
      "facts": ["调查员杀死绑架者"],
      "player_visible_information": [
        {
          "text": "绑架者倒在长廊中，再也无法阻止你离开。",
          "visibility": {"audience": "all"}
        }
      ]
    }
  ],
  "information_items": [
    {
      "id": "initial_lock_warning",
      "content": "桌面字条写着：“不要妄想离开这里了，你已经被［锁住］了。”",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "sketchbook_rule",
      "content": "速写本撕下的画页能把无生命物实体化，但物品必须是可以用平面表现构造的简单物品；全本只剩四页。",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "corridor_danger_warning",
      "content": "中间抽屉的字条警告：“当你以为安全的时候，就是你最危险的时候。”",
      "visibility": {"audience": "keeper"}
    },
    {
      "id": "silver_lock_principle",
      "content": "银之锁以活着的芭斯特为核心，把调查员束缚在特定区域；核心死亡时法术解除。",
      "visibility": {"audience": "keeper"}
    }
  ]
}
