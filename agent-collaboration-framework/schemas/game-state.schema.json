{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "game-state.schema.json",
  "$defs": {
    "ActorState": {
      "additionalProperties": false,
      "properties": {
        "player_id": {
          "title": "Player Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "player_id",
        "name"
      ],
      "title": "ActorState",
      "type": "object"
    },
    "JsonValue": {}
  },
  "additionalProperties": false,
  "description": "Authoritative state shape used by the fake engine, never workflow state.",
  "properties": {
    "room_id": {
      "title": "Room Id",
      "type": "string"
    },
    "scene_id": {
      "title": "Scene Id",
      "type": "string"
    },
    "phase": {
      "default": "playing",
      "enum": [
        "playing",
        "ended"
      ],
      "title": "Phase",
      "type": "string"
    },
    "ending_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ending Id"
    },
    "event_sequence": {
      "default": 0,
      "minimum": 0,
      "title": "Event Sequence",
      "type": "integer"
    },
    "actors": {
      "additionalProperties": {
        "$ref": "#/$defs/ActorState"
      },
      "title": "Actors",
      "type": "object"
    },
    "entities": {
      "additionalProperties": {
        "additionalProperties": {
          "$ref": "#/$defs/JsonValue"
        },
        "type": "object"
      },
      "title": "Entities",
      "type": "object"
    }
  },
  "required": [
    "room_id",
    "scene_id",
    "actors",
    "entities"
  ],
  "title": "GameState",
  "type": "object"
}
