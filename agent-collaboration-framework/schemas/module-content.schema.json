      "type": "object"
    },
    "CheckpointOutcomesSpec": {
      "additionalProperties": false,
      "properties": {
        "success": {
          "$ref": "#/$defs/CheckpointOutcomeSpec"
        },
        "failure": {
          "$ref": "#/$defs/CheckpointOutcomeSpec"
        },
        "critical_success": {
          "anyOf": [
            {
              "$ref": "#/$defs/CheckpointOutcomeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "extreme_success": {
          "anyOf": [
            {
              "$ref": "#/$defs/CheckpointOutcomeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "hard_success": {
          "anyOf": [
            {
              "$ref": "#/$defs/CheckpointOutcomeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "regular_success": {
          "anyOf": [
            {
              "$ref": "#/$defs/CheckpointOutcomeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fumble": {
          "anyOf": [
            {
              "$ref": "#/$defs/CheckpointOutcomeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "success",
        "failure"
      ],
      "title": "CheckpointOutcomesSpec",
      "type": "object"
    },
    "CheckpointSpec": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "scene_id": {
          "minLength": 1,
          "title": "Scene Id",
          "type": "string"
        },
        "action": {
          "minLength": 1,
          "title": "Action",
          "type": "string"
        },
        "target_id": {
          "minLength": 1,
          "title": "Target Id",
          "type": "string"
        },
        "skills": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        },
        "difficulty": {
          "anyOf": [
            {
              "enum": [
                "regular",
                "hard",
                "extreme"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Difficulty"
