    "JsonValue": {},
    "ModifyOperationSpec": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "modify",
          "default": "modify",
          "title": "Op",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "set": {
          "$ref": "#/$defs/JsonValue"
