        "id",
        "scene_id",
        "action",
        "target_id",
        "outcomes"
      ],
      "title": "CheckpointSpec",
      "type": "object"
    },
    "ConditionSpec": {
      "additionalProperties": false,
      "description": "Exactly one of ``path + equals`` or ``expr``.",
      "properties": {
        "path": {
          "default": "",
          "title": "Path",
          "type": "string"
        },
        "equals": {
          "anyOf": [
            {
              "$ref": "#/$defs/JsonValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "expr": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expr"
        }
      },
      "title": "ConditionSpec",
      "type": "object"
    },
    "EntitySpec": {
