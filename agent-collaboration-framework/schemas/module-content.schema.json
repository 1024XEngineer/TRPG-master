  "$id": "module-content.schema.json",
  "$defs": {
    "AbsorbOperationSpec": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "absorb",
          "default": "absorb",
          "title": "Op",
          "type": "string"
        },
        "amount": {
          "minLength": 1,
          "title": "Amount",
          "type": "string"
        },
        "decrement": {
          "minLength": 1,
          "title": "Decrement",
          "type": "string"
        }
      },
      "required": [
        "amount",
        "decrement"
      ],
      "title": "AbsorbOperationSpec",
      "type": "object"
    },
    "AddOperationSpec": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "add",
          "default": "add",
          "title": "Op",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "path",
        "value"
      ],
      "title": "AddOperationSpec",
      "type": "object"
    },
    "AllowOperationSpec": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "allow",
          "default": "allow",
          "title": "Op",
          "type": "string"
        },
        "action": {
          "minLength": 1,
          "title": "Action",
          "type": "string"
        }
      },
      "required": [
        "action"
      ],
      "title": "AllowOperationSpec",
      "type": "object"
    },
    "ApplyConditionSpec": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "apply_condition",
          "default": "apply_condition",
          "title": "Op",
          "type": "string"
        },
        "condition": {
          "minLength": 1,
          "title": "Condition",
          "type": "string"
        }
      },
      "required": [
        "condition"
      ],
      "title": "ApplyConditionSpec",
      "type": "object"
    },
    "CheckpointOutcomeSpec": {
      "additionalProperties": false,
      "properties": {
        "facts": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Facts",
          "type": "array"
        },
        "player_visible_information": {
          "default": [],
          "items": {
            "$ref": "#/$defs/VisibleInformation"
          },
          "title": "Player Visible Information",
          "type": "array"
        },
        "narration_constraints": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Narration Constraints",
          "type": "array"
        },
        "ops": {
          "default": [],
          "items": {
            "discriminator": {
              "mapping": {
                "absorb": "#/$defs/AbsorbOperationSpec",
                "add": "#/$defs/AddOperationSpec",
                "allow": "#/$defs/AllowOperationSpec",
                "apply_condition": "#/$defs/ApplyConditionSpec",
                "forbid": "#/$defs/ForbidOperationSpec",
                "force": "#/$defs/ForceOperationSpec",
                "modify": "#/$defs/ModifyOperationSpec",
                "scale": "#/$defs/ScaleOperationSpec",
                "set": "#/$defs/SetOperationSpec",
                "transition": "#/$defs/TransitionSpec",
                "trigger_ending": "#/$defs/TriggerEndingSpec",
                "trigger_rule": "#/$defs/TriggerRuleSpec"
              },
              "propertyName": "op"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/AllowOperationSpec"
              },
              {
                "$ref": "#/$defs/ModifyOperationSpec"
              },
              {
                "$ref": "#/$defs/SetOperationSpec"
              },
              {
                "$ref": "#/$defs/ScaleOperationSpec"
              },
              {
                "$ref": "#/$defs/AddOperationSpec"
              },
              {
                "$ref": "#/$defs/AbsorbOperationSpec"
              },
              {
                "$ref": "#/$defs/ForbidOperationSpec"
              },
              {
                "$ref": "#/$defs/ForceOperationSpec"
              },
              {
                "$ref": "#/$defs/ApplyConditionSpec"
              },
              {
                "$ref": "#/$defs/TriggerEndingSpec"
              },
              {
                "$ref": "#/$defs/TriggerRuleSpec"
              },
              {
                "$ref": "#/$defs/TransitionSpec"
              }
            ]
          },
