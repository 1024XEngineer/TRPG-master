        "outcomes": {
          "$ref": "#/$defs/CheckpointOutcomesSpec"
        },
        "visibility": {
          "anyOf": [
            {
              "$ref": "#/$defs/VisibilityPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
