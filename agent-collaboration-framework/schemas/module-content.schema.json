        "mode": {
          "default": "append",
          "enum": [
            "append",
            "override",
            "forbid"
          ],
          "title": "Mode",
          "type": "string"
        },
        "when": {
          "$ref": "#/$defs/ConditionSpec"
        },
        "then": {
          "default": [],
          "items": {
            "discriminator": {
              "mapping": {
                "absorb": "#/$defs/AbsorbOperationSpec",
                "add": "#/$defs/AddOperationSpec",
                "allow": "#/$defs/AllowOperationSpec",
                "apply_condition": "#/$defs/ApplyConditionSpec",
                "forbid": "#/$defs/ForbidOperationSpec",
                "force": "#/$defs/ForceOperationSpec",
                "modify": "#/$defs/ModifyOperationSpec",
                "scale": "#/$defs/ScaleOperationSpec",
                "set": "#/$defs/SetOperationSpec",
                "transition": "#/$defs/TransitionSpec",
                "trigger_ending": "#/$defs/TriggerEndingSpec",
                "trigger_rule": "#/$defs/TriggerRuleSpec"
              },
              "propertyName": "op"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/AllowOperationSpec"
              },
              {
                "$ref": "#/$defs/ModifyOperationSpec"
              },
              {
                "$ref": "#/$defs/SetOperationSpec"
              },
              {
                "$ref": "#/$defs/ScaleOperationSpec"
              },
              {
                "$ref": "#/$defs/AddOperationSpec"
              },
              {
                "$ref": "#/$defs/AbsorbOperationSpec"
              },
              {
                "$ref": "#/$defs/ForbidOperationSpec"
              },
              {
                "$ref": "#/$defs/ForceOperationSpec"
              },
              {
                "$ref": "#/$defs/ApplyConditionSpec"
              },
              {
                "$ref": "#/$defs/TriggerEndingSpec"
              },
              {
                "$ref": "#/$defs/TriggerRuleSpec"
              },
              {
                "$ref": "#/$defs/TransitionSpec"
              }
            ]
          },
          "title": "Then",
          "type": "array"
        },
        "facts": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Facts",
          "type": "array"
        },
        "player_visible_information": {
          "default": [],
          "items": {
            "$ref": "#/$defs/VisibleInformation"
          },
          "title": "Player Visible Information",
          "type": "array"
        }
      },
      "required": [
        "id",
        "hook",
        "when"
      ],
      "title": "RuleSpec",
      "type": "object"
    },
    "ScaleOperationSpec": {
      "additionalProperties": false,
