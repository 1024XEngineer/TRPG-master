            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "secrets": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
