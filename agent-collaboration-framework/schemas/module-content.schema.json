        "information_item_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Information Item Ids",
          "type": "array"
        },
        "state": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "State",
          "type": "object"
        },
        "refuse_ops": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Refuse Ops",
          "type": "array"
        },
        "blocked_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Blocked Text"
        },
        "direct_responses": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Direct Responses",
          "type": "object"
        },
        "rules": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RuleSpec"
          },
          "title": "Rules",
          "type": "array"
        },
        "stat_block": {
          "anyOf": [
            {
              "$ref": "#/$defs/StatBlock"
