{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "narration-request.schema.json",
  "$defs": {
    "CheckpointOption": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "action": {
          "title": "Action",
          "type": "string"
        },
        "target_id": {
          "title": "Target Id",
          "type": "string"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        }
      },
      "required": [
        "id",
        "action",
        "target_id"
      ],
      "title": "CheckpointOption",
      "type": "object"
    },
    "NarrationFact": {
      "additionalProperties": false,
      "description": "允许 Narrator 引用的一条玩家可见事实。",
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "id",
        "text"
      ],
      "title": "NarrationFact",
      "type": "object"
    },
    "PublicResultStatus": {
      "additionalProperties": false,
      "description": "Narrator 为组织语气所需的最小公开裁决状态。",
      "properties": {
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "resolution": {
          "enum": [
            "checkpoint",
            "direct",
            "blocked",
            "unrecognized"
          ],
          "title": "Resolution",
          "type": "string"
        }
      },
      "required": [
        "success",
        "resolution"
      ],
      "title": "PublicResultStatus",
      "type": "object"
    },
    "TurnContext": {
      "additionalProperties": false,
      "properties": {
        "scene_id": {
          "title": "Scene Id",
          "type": "string"
        },
        "phase": {
          "enum": [
            "playing",
            "ended"
          ],
          "title": "Phase",
          "type": "string"
        },
        "visible_entities": {
          "items": {
            "$ref": "#/$defs/VisibleEntity"
          },
          "title": "Visible Entities",
          "type": "array"
        },
        "checkpoint_options": {
          "items": {
            "$ref": "#/$defs/CheckpointOption"
          },
          "title": "Checkpoint Options",
          "type": "array"
        }
      },
      "required": [
        "scene_id",
        "phase"
      ],
      "title": "TurnContext",
      "type": "object"
    },
    "VisibleEntity": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "npc",
            "object",
            "location"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "narrative_actions": {
          "items": {
            "type": "string"
          },
          "title": "Narrative Actions",
          "type": "array"
        }
      },
      "required": [
        "id",
        "kind",
        "name",
        "content"
      ],
      "title": "VisibleEntity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "经过安全投影后才允许序列化给 Narrator 的输入。",
  "properties": {
    "utterance": {
      "minLength": 1,
      "title": "Utterance",
      "type": "string"
    },
    "context": {
      "$ref": "#/$defs/TurnContext"
    },
    "player_visible_facts": {
      "items": {
        "$ref": "#/$defs/NarrationFact"
      },
      "title": "Player Visible Facts",
      "type": "array"
    },
    "narration_constraints": {
      "items": {
        "type": "string"
      },
      "title": "Narration Constraints",
      "type": "array"
    },
    "result_status": {
      "anyOf": [
        {
          "$ref": "#/$defs/PublicResultStatus"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "utterance",
    "context"
  ],
  "title": "NarrationRequest",
  "type": "object"
}
