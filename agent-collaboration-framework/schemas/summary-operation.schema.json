{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "summary-operation.schema.json",
  "additionalProperties": false,
  "description": "Non-authoritative proposal returned to the host; it is not persisted here.",
  "properties": {
    "op": {
      "const": "append_turn_summary",
      "default": "append_turn_summary",
      "title": "Op",
      "type": "string"
    },
    "room_id": {
      "title": "Room Id",
      "type": "string"
    },
    "client_action_id": {
      "title": "Client Action Id",
      "type": "string"
    },
    "text": {
      "title": "Text",
      "type": "string"
    },
    "source_event_ids": {
      "items": {
        "type": "string"
      },
      "title": "Source Event Ids",
      "type": "array"
    }
  },
  "required": [
    "room_id",
    "client_action_id",
    "text"
  ],
  "title": "SummaryOperation",
  "type": "object"
}
