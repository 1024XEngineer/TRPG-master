{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "turn-context.schema.json",
  "$defs": {
    "CheckpointOption": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "action": {
          "title": "Action",
          "type": "string"
        },
        "target_id": {
          "title": "Target Id",
          "type": "string"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        }
      },
      "required": [
        "id",
        "action",
        "target_id"
      ],
      "title": "CheckpointOption",
      "type": "object"
    },
    "VisibleEntity": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "npc",
            "object",
            "location"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind",
        "name",
        "content"
      ],
      "title": "VisibleEntity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "scene_id": {
      "title": "Scene Id",
      "type": "string"
    },
    "phase": {
      "enum": [
        "playing",
        "ended"
      ],
      "title": "Phase",
      "type": "string"
    },
    "visible_entities": {
      "items": {
        "$ref": "#/$defs/VisibleEntity"
      },
      "title": "Visible Entities",
      "type": "array"
    },
    "checkpoint_options": {
      "items": {
        "$ref": "#/$defs/CheckpointOption"
      },
      "title": "Checkpoint Options",
      "type": "array"
    }
  },
  "required": [
    "scene_id",
    "phase"
  ],
  "title": "TurnContext",
  "type": "object"
}
